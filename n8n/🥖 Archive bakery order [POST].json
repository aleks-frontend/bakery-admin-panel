        "jsCode": "const body = $input.first().json.body;\n\nlet orderIds = [];\nif (body.orderIds && Array.isArray(body.orderIds)) {\n  orderIds = body.orderIds;\n} else if (body.orderId) {\n  orderIds = [body.orderId];\n} else {\n  return [{ json: { success: false, error: \"Missing orderIds\" } }];\n}\n\nif (orderIds.length === 0) {\n  return [{ json: { success: false, error: \"orderIds array is empty\" } }];\n}\n\nreturn orderIds.map(orderId => ({ json: { orderId } }));"
