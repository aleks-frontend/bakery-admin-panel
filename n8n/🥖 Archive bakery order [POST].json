        "jsCode": "// Sort by row_number descending so rows are deleted bottom-to-top,\n// preventing row-number shifting when deleting multiple rows from Sheet1.\nconst items = $input.all();\nreturn items\n  .sort((a, b) => b.json.row_number - a.json.row_number)\n  .map(item => ({\n    json: {\n      row_number: item.json.row_number,\n      \"Order ID\": item.json[\"Order ID\"],\n      \"Recipient\": item.json[\"Recipient\"],\n      \"Phone\": item.json[\"Phone\"],\n      \"Email\": item.json[\"Email\"],\n      \"Date\": item.json[\"Date\"],\n      \"Location\": item.json[\"Location\"],\n      \"Ordered articles\": item.json[\"Ordered articles\"],\n      \"Total price\": item.json[\"Total price\"],\n      \"Status\": item.json[\"Status\"],\n      \"Remark\": item.json[\"Remark\"]\n    }\n  }));",
        "mode": "runOnceForAllItems"
