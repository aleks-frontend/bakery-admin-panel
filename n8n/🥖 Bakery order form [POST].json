      "parameters": {
        "jsCode": "// Uzimamo podatke iz prethodnih node-ova\nconst order = $input.first().json;\n\n// Ordered articles dolaze iz Validate node-a\nconst orderedArticlesRaw = $('Validate prices and availability')\n  .first()\n  .json\n  .orderedArticles;\n\n// Razdvajamo artikle po \"•\"\nconst articles = orderedArticlesRaw\n  .split(\"•\")\n  .map(a => a.trim())\n  .filter(Boolean);\n\n// Formiramo lep email tekst (bez markdown-a)\nconst orderDetailsText = [\n  ...articles.map(a => `• ${a}`),\n].join(\"<br />\");\n\n// Vraćamo vrednosti koje ćeš koristiti u Gmail node-u\nreturn [\n  {\n    json: {\n      detalji_porudzbine: orderDetailsText,\n      ukupan_iznos: order[\"Total price\"],\n      ime: order.Recipient\n    }\n  }\n];\n"
