    {
      "parameters": {
        "jsCode": "function getNextFirstFriday(fromDate = new Date()) {\n  const date = new Date(fromDate);\n  date.setHours(0, 0, 0, 0);\n\n  // Prelazimo na sledeći mesec ako smo već posle prvog petka\n  const year = date.getFullYear();\n  let month = date.getMonth();\n\n  function firstFriday(year, month) {\n    const d = new Date(year, month, 1);\n    const day = d.getDay(); // 0=Sun, 5=Fri\n    const offset = (5 - day + 7) % 7;\n    d.setDate(1 + offset);\n    return d;\n  }\n\n  let friday = firstFriday(year, month);\n  if (friday <= date) {\n    month += 1;\n    friday = firstFriday(year, month);\n  }\n\n  return friday.toISOString().split(\"T\")[0]; // YYYY-MM-DD\n}\n\nreturn [\n  {\n    json: {\n      reminderDate: getNextFirstFriday(),\n    }\n  }\n];"
      },
