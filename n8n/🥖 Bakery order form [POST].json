        "jsCode": "const row = $input.first().json;\n\nconst recipient = row.recipient || \"\";\nconst lang = (row.Language || \"sr\").toLowerCase();\nconst orderDetails = row.detalji_porudzbine || \"\";\nconst totalPrice = row.totalPrice || \"\";\n\nconst orderLink = row.orderLink || \"https://order.lisztrapszodia.in.rs/\"; // može da vodi na stranicu sa porudžbinom\n\nlet subject = \"\";\nlet intro = \"\";\nlet closing = \"\";\nlet buttonText = \"\";\n\nif (lang === \"hu\") {\n  subject = \"Rendelés megerősítve – Liszt Rapszodia\";\n\n  intro = `Tisztelt ${recipient},<br/><br/>\nKöszönjük rendelését!<br/>\nRendelését sikeresen megkaptuk, és feldolgozás alatt áll.`;\n\n  buttonText = \"Rendelés megtekintése\";\n\n  closing = `\nAmennyiben bármilyen kérdés vagy további információra lenne szükség, felvesszük Önnel a kapcsolatot a megadott telefonszámon.<br/><br/>\nKöszönjük bizalmát, és örömmel készítjük el Önnek a friss termékeket.<br/><br/>\nÜdvözlettel,<br/>\n🎼 <strong>Liszt Rapszodia</strong><br/>\n📧 order@lisztrapszodia.in.rs\n`;\n\n} \nelse if (lang === \"en\") {\n  subject = \"Order Confirmation – Liszt Rapszodia\";\n\n  intro = `Dear ${recipient},<br/><br/>\nThank you for your order!<br/>\nWe have successfully received your order and it is now being processed.`;\n\n  buttonText = \"View Order\";\n\n  closing = `\nIf you have any questions or need further information, we will contact you at the provided phone number.<br/><br/>\nThank you for your trust, and we look forward to preparing fresh products for you.<br/><br/>\nBest regards,<br/>\n🎼 <strong>Liszt Rapszodia</strong><br/>\n📧 order@lisztrapszodia.in.rs\n`;\n\n} \nelse {\n  subject = \"Potvrda porudžbine – Liszt Rapszodia\";\n\n  intro = `Poštovani/a ${recipient},<br/><br/>\nHvala na vašoj porudžbini!<br/>\nVaša porudžbina je uspešno primljena i u obradi je.`;\n\n  buttonText = \"Pogledaj porudžbinu\";\n\n  closing = `\nUkoliko imate bilo kakvih pitanja ili trebate dodatne informacije, kontaktiraćemo vas na datom broju telefona.<br/><br/>\nHvala na poverenju i radujemo se da vam pripremimo sveže proizvode.<br/><br/>\nSrdačan pozdrav,<br/>\n🎼 <strong>Liszt Rapszodia</strong><br/>\n📧 order@lisztrapszodia.in.rs\n`;\n\n}\n\nconst html = `\n<div style=\"font-family:Arial,Helvetica,sans-serif;background:#f7f7f7;padding:30px;\">\n  <div style=\"max-width:520px;margin:auto;background:white;border-radius:10px;padding:30px;border:1px solid #eee;\">\n\n    <h2 style=\"margin-top:0;color:#333;\">🎼 Liszt Rapszodia</h2>\n\n    <p style=\"font-size:15px;color:#444;line-height:1.6;\">\n      ${intro}\n    </p>\n\n    <div style=\"margin:20px 0;padding:15px;border:1px solid #eee;border-radius:8px;background:#fafafa;\">\n      ${orderDetails}\n      <p style=\"font-weight:bold;margin-top:10px;\">Végösszeg / Total: <strong>${totalPrice} RSD</strong></p>\n    </div>\n\n    <div style=\"text-align:center;margin:25px 0;\">\n      <a href=\"${orderLink}\" \n         style=\"\n         background:#b8860b;\n         color:white;\n         padding:14px 24px;\n         text-decoration:none;\n         border-radius:8px;\n         font-size:16px;\n         font-weight:bold;\n         display:inline-block;\">\n         ${buttonText}\n      </a>\n    </div>\n\n    <p style=\"font-size:14px;color:#444;line-height:1.6;\">\n      ${closing}\n    </p>\n\n    <hr style=\"border:none;border-top:1px solid #eee;margin:25px 0;\">\n\n    <p style=\"font-size:12px;color:#888;\">\n      🎼 Liszt Rapszodia<br/>\n      📧 order@lisztrapszodia.in.rs\n    </p>\n\n  </div>\n</div>\n`;\n\nreturn [\n  {\n    json: {\n      email: row.Email,\n      subject,\n      html\n    }\n  }\n];"
      },
